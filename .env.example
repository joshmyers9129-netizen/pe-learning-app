# Copy this file to .env.local on your local machine.
# NEVER commit .env.local to GitHub — it contains your real API key.

# Optional: enable the AI helper UI (set to "true" to show AI buttons)
NEXT_PUBLIC_AI_ENABLED=false

# Optional: your OpenRouter API key (https://openrouter.ai)
# Required for AI helper to function. Leave blank to disable.
OPENROUTER_API_KEY=
